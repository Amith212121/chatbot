CHAT_PROVIDER=ollama
OLLAMA_MODEL=tinyllama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_MS=15000
OLLAMA_NUM_CTX=512
OLLAMA_NUM_THREAD=4
OLLAMA_NUM_PREDICT=350
OLLAMA_TEMPERATURE=0.1
OLLAMA_KEEP_ALIVE=120m

# Reply quality controls
OLLAMA_MAX_CONTINUATIONS=0
OLLAMA_MAX_WORDS=200

# Per-minute burst rate limiting
CHAT_RATE_LIMIT_MAX=20
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_MAX_MESSAGE_LENGTH=1200

# Daily question limit  ← NEW
# How many questions a single IP can ask per day. Resets at midnight.
# Change this number to adjust the limit without touching any code.
CHAT_DAILY_LIMIT=5
# Use sqlite in production so quota is shared across workers/processes.
CHAT_DAILY_STORE=sqlite
CHAT_DAILY_SQLITE_PATH=./wavemind_daily_quota.sqlite3
CHAT_DAILY_SQLITE_TIMEOUT_MS=5000

# Chat history logging in Postgres
# Enable with: CHAT_HISTORY_STORE=postgres
# Keep disabled by default until Postgres URL is ready.
CHAT_HISTORY_STORE=disabled
# Use either CHAT_HISTORY_DATABASE_URL or DATABASE_URL
# Example: postgres://username:password@localhost:5432/wavemind
CHAT_HISTORY_DATABASE_URL=
CHAT_HISTORY_CONNECT_TIMEOUT_S=5

PORT=8000
FLASK_DEBUG=false
